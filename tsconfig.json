{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // ✅ so TS is happy with JS + JSON imports
    "allowJs": true,
    "resolveJsonModule": true,

    // Vite/React globals
    "types": ["vite/client"]
  },
  "include": ["src"]
}