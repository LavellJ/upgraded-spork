{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "react-jsx",

    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "isolatedModules": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    // ✅ so TS is happy with JS + JSON imports
    "allowJs": true,
    "resolveJsonModule": true,

    // Vite/React globals and path mapping
    "baseUrl": ".",
    "types": ["vite/client", "node"],
    "paths": {
      "@/*": ["client/src/*"],
      "@shared/*": ["shared/*"]
    }
  },
  "include": ["client/src", "shared", "prompts"]
}