        ]
      },
      "transcript": {
        "text": {
          "en-AU": "Today we'll learn how to find the main idea in a text! The main idea is the most important message the author wants you to understand. It's like the big picture that all the details support. We'll practice identifying main ideas using key details and asking the right questions."
        }
      },
      "alt": "Instructional video for Finding Main Ideas",
      "ariaLabel": "Interactive video player: Finding Main Ideas"
    },
    {
      "kind": "guided_practice",
      "id": "guided_aS1pRt6u",
      "title": {
        "en-AU": "Practice: Finding Main Ideas"
      },
      "steps": [
        {
          "id": "step_1_bT2qSu7v",
          "instruction": {
            "en-AU": "Step 1"
          },
          "question": {
            "en-AU": "When you read a story, what question should you ask to find the main idea?"
          },
          "correctAnswer": "What is this mostly about?",
          "hints": [
            {
              "en-AU": "The main idea tells us the overall topic or message."
            },
            {
              "en-AU": "Think about the big picture, not small details."
            }
          ],
          "branchingPaths": {
            "main_idea_confusion": {
              "condition": "incorrect",
              "remediation": {
                "en-AU": "Let's try again. The main idea tells us the overall topic or message."
              },
              "nextHint": {
                "en-AU": "Think about the big picture, not small details."
              }
            }
          }
        },
        {
          "id": "step_2_cU3rTv8w",
          "instruction": {
            "en-AU": "Step 2"
          },
          "question": {
            "en-AU": "Where can you usually find clues about the main idea?"
          },
          "correctAnswer": "Throughout the whole text",
          "hints": [
            {
              "en-AU": "Main idea clues appear in many parts of the text."
            },
            {
              "en-AU": "Look for repeated words and important details everywhere."
            }
          ]
        },
        {
          "id": "step_3_dV4sUw9x",
          "instruction": {
            "en-AU": "Step 3"
          },
          "question": {
            "en-AU": "Read this paragraph: 'Dogs make great pets. They are loyal and friendly. Dogs can be trained to help people. Many families love having dogs.' What is the main idea?"
          },
          "correctAnswer": "Dogs make great pets",
          "hints": [
            {
              "en-AU": "Look at what all the sentences have in common."
            },
            {
              "en-AU": "All the details support the idea that dogs are wonderful companions."
            }
          ]
        }
      ]
    },
