      "transcript": {
        "text": {
          "en-AU": "Today we'll learn how to find key details in a text! Key details are important facts that support the main idea. They help us understand and remember what we read. We'll practice spotting these important details and using them to answer questions."
        }
      },
      "alt": "Instructional video for Finding Key Details",
      "ariaLabel": "Interactive video player: Finding Key Details"
    },
    {
      "kind": "guided_practice",
      "id": "guided_cD5fGh9i",
      "title": {
        "en-AU": "Practice: Finding Key Details"
      },
      "steps": [
        {
          "id": "step_1_eE7gIj0k",
          "instruction": {
            "en-AU": "Step 1"
          },
          "question": {
            "en-AU": "What are key details in a text?"
          },
          "correctAnswer": "Important facts that support the main idea",
          "hints": [
            {
              "en-AU": "Key details help explain and support the main message."
            },
            {
              "en-AU": "They are specific facts, not opinions or small unimportant details."
            }
          ],
          "branchingPaths": {
            "key_detail_confusion": {
              "condition": "incorrect",
              "remediation": {
                "en-AU": "Let's try again. Key details help explain and support the main message."
              },
              "nextHint": {
                "en-AU": "They are specific facts, not opinions or small unimportant details."
              }
            }
          }
        },
        {
          "id": "step_2_gF9hKl2m",
          "instruction": {
            "en-AU": "Step 2"
          },
          "question": {
            "en-AU": "Read: 'Bees are important insects. They help plants grow by moving pollen. Bees make honey in their hives.' What is a key detail?"
          },
          "correctAnswer": "They help plants grow by moving pollen",
          "hints": [
            {
              "en-AU": "Look for specific facts that tell us more about bees."
            },
            {
              "en-AU": "This detail explains why bees are important."
            }
          ]
        },
        {
          "id": "step_3_iH1jMn4o",
          "instruction": {
            "en-AU": "Step 3"
          },
          "question": {
            "en-AU": "Which question helps you find key details?"
          },
          "correctAnswer": "What specific facts support the main idea?",
          "hints": [
            {
              "en-AU": "Look for questions that ask about specific information."
            },
            {
              "en-AU": "Key details answer who, what, when, where, why, and how questions."
            }
          ]
        }
      ]
    },
