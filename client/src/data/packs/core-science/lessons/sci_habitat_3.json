        "en-AU": "Practice: Animal Habitats"
      },
      "steps": [
        {
          "id": "step_1_oG5hFi0j",
          "instruction": {
            "en-AU": "Step 1"
          },
          "question": {
            "en-AU": "What do all living things need to survive?"
          },
          "correctAnswer": "Food, water, shelter, air",
          "hints": [
            {
              "en-AU": "Think about what plants and animals both need to live."
            },
            {
              "en-AU": "Consider the basic needs for any living creature."
            }
          ],
          "branchingPaths": {
            "basic_needs_confusion": {
              "condition": "incorrect",
              "remediation": {
                "en-AU": "Let's try again. Think about what plants and animals both need to live."
              },
              "nextHint": {
                "en-AU": "Consider the basic needs for any living creature."
              }
            }
          }
        },
        {
          "id": "step_2_pH6iGj1k",
          "instruction": {
            "en-AU": "Step 2"
          },
          "question": {
            "en-AU": "Where do desert animals find water?"
          },
          "correctAnswer": "From their food and stored in their bodies",
          "hints": [
            {
              "en-AU": "Desert animals have special ways to get and save water."
            },
            {
              "en-AU": "Some animals get water from the food they eat."
            }
          ]
        },
        {
          "id": "step_3_qI7jHk2l",
          "instruction": {
            "en-AU": "Step 3"
          },
          "question": {
            "en-AU": "How do polar bears stay warm in the Arctic?"
          },
          "correctAnswer": "Thick fur and fat layer",
          "hints": [
            {
              "en-AU": "Polar bears have special body features for cold weather."
            },
            {
              "en-AU": "Think about what covers their body to keep heat in."
            }
          ]
        }
      ]
