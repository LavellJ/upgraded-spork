      "transcript": {
        "text": {
          "en-AU": "Welcome to learning about equivalent fractions! Today we'll discover that different fractions can represent the same amount. When we have 1/2 and 2/4, they look different but they're actually equal. Let's explore how to identify and create equivalent fractions using visual models and number patterns."
        }
      },
      "alt": "Instructional video for Fraction Equivalence",
      "ariaLabel": "Interactive video player: Fraction Equivalence"
    },
    {
      "kind": "guided_practice",
      "id": "guided_n7Hp5Wq1",
      "title": {
        "en-AU": "Practice: Fraction Equivalence"
      },
      "steps": [
        {
          "id": "step_1_rT3kMx8z",
          "instruction": {
            "en-AU": "Step 1"
          },
          "question": {
            "en-AU": "Look at these circles. 1/2 is shaded in one circle, 2/4 is shaded in another. Are these fractions equal?"
          },
          "correctAnswer": "Yes, they represent the same amount",
          "hints": [
            {
              "en-AU": "When you have the same amount of shading, the fractions are equivalent."
            },
            {
              "en-AU": "Think of cutting a pizza in half versus cutting it into fourths and taking 2 pieces."
            }
          ],
          "branchingPaths": {
            "fraction_equiv_confusion": {
              "condition": "incorrect",
              "remediation": {
                "en-AU": "Let's try again. When you have the same amount of shading, the fractions are equivalent."
              },
              "nextHint": {
                "en-AU": "Think of cutting a pizza in half versus cutting it into fourths and taking 2 pieces."
              }
            }
          }
        },
        {
          "id": "step_2_xY9mKp7r",
          "instruction": {
            "en-AU": "Step 2"
          },
          "question": {
            "en-AU": "If 1/2 = 2/4, what would be an equivalent fraction to 1/3?"
          },
          "correctAnswer": "2/6",
          "hints": [
            {
              "en-AU": "Multiply both the top and bottom numbers by the same amount."
            },
            {
              "en-AU": "If we multiply 1/3 by 2/2, we get 2/6."
            }
          ]
        },
        {
          "id": "step_3_pL8nRw6t",
          "instruction": {
            "en-AU": "Step 3"
          },
          "question": {
            "en-AU": "Which fraction is equivalent to 3/4?"
          },
          "correctAnswer": "6/8",
          "hints": [
            {
              "en-AU": "Multiply both numbers by 2 to find an equivalent fraction."
            },
            {
              "en-AU": "3 × 2 = 6 and 4 × 2 = 8, so 6/8 is equivalent to 3/4."
            }
          ]
        }
      ]
    },
