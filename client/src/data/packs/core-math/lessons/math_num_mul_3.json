      "transcript": {
        "text": {
          "en-AU": "Welcome to learning about multiplication! Multiplication is a way of adding equal groups together quickly. When we see 3 × 4, it means we have 3 groups with 4 items in each group. Let's explore how to visualize and solve multiplication problems using equal groups."
        }
      },
      "alt": "Instructional video for Multiplication as Equal Groups",
      "ariaLabel": "Interactive video player: Multiplication as Equal Groups"
    },
    {
      "kind": "guided_practice",
      "id": "guided_cI6oLy8a",
      "title": {
        "en-AU": "Practice: Multiplication as Equal Groups"
      },
      "steps": [
        {
          "id": "step_1_nU0sRx9b",
          "instruction": {
            "en-AU": "Step 1"
          },
          "question": {
            "en-AU": "Look at 4 groups with 3 apples in each group. What multiplication sentence represents this?"
          },
          "correctAnswer": "4 × 3",
          "hints": [
            {
              "en-AU": "Count the number of groups first, then the number in each group."
            },
            {
              "en-AU": "4 groups × 3 apples in each group = 4 × 3."
            }
          ]
        },
        {
          "id": "step_2_pV1tSy0c",
          "instruction": {
            "en-AU": "Step 2"
          },
          "question": {
            "en-AU": "What does 5 × 2 mean in words?"
          },
          "correctAnswer": "5 groups of 2",
          "hints": [
            {
              "en-AU": "The first number tells us how many groups we have."
            },
            {
              "en-AU": "The second number tells us how many are in each group."
            }
          ]
        },
        {
          "id": "step_3_qW2uTz1d",
          "instruction": {
            "en-AU": "Step 3"
          },
          "question": {
            "en-AU": "Calculate 3 × 6 by adding equal groups."
          },
          "correctAnswer": "18",
          "hints": [
            {
              "en-AU": "Add 6 + 6 + 6 (three groups of 6)."
            },
            {
              "en-AU": "6 + 6 + 6 = 18, so 3 × 6 = 18."
            }
          ]
        }
      ]
    },
