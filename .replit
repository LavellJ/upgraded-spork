modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm ci && npm run build && npm run preview"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
run = ["npm", "run", "start"]

[[ports]]
localPort = 4173
externalPort = 3000
exposeLocalhost = true

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 5173

[env]
PORT = "5000"

[workflows]
runButton = "Unified Server"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Unified Server"
mode = "sequential"
author = 46746148

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash -lc './start.sh'"

[agent]
integrations = ["javascript_openai==1.0.0", "javascript_mem_db==1.0.0", "javascript_object_storage==1.0.0", "javascript_database==1.0.0"]
